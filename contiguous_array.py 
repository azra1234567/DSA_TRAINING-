class Solution:
    def findMaxLength(self, nums):
        prefix_sum = 0
        hashmap = {0: -1}
        max_len = 0

        for i in range(len(nums)):
            if nums[i] == 0:
                prefix_sum -= 1
            else:
                prefix_sum += 1

            if prefix_sum in hashmap:
                max_len = max(max_len, i - hashmap[prefix_sum])
            else:
                hashmap[prefix_sum] = i

        return max_len